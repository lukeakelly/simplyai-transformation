generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Horizon {
  id        String   @id @default(cuid())
  name      String
  order     Int
  startDate DateTime?
  endDate   DateTime?
  color     String    @default("#2563eb")
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Person {
  id               String   @id @default(cuid())
  name             String   @unique
  title            String?
  email            String?
  ownedTasks       Task[]   @relation("OwnerTasks")
  accountableTasks Task[]   @relation("AccountableTasks")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Task {
  id              String    @id @default(cuid())
  itemId          String?   @unique
  workstream      String
  category        String?
  title           String
  description     String?
  whyItMatters    String?
  output          String?
  artefactType    String?
  ownerRole       String?
  ownerId         String?
  owner           Person?   @relation("OwnerTasks", fields: [ownerId], references: [id])
  accountableId   String?
  accountable     Person?   @relation("AccountableTasks", fields: [accountableId], references: [id])
  contributors    String?
  priority        String?
  horizonId       String?
  horizon         Horizon?  @relation(fields: [horizonId], references: [id])
  targetDate      DateTime?
  status          String    @default("Not Started")
  completion      Int       @default(0)
  recurrence      String?
  cadence         String?
  dependencies    String?
  risks           String?
  evidence        String?
  doneCriteria    String?
  source          String?
  notes           String?
  position        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([horizonId])
  @@index([workstream])
  @@index([status])
}
