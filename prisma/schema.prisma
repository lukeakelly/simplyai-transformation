generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String
  permission   String   @default("editor")
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorRole  String
  action     String
  entityType String
  entityId   String?
  entityName String?
  summary    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Horizon {
  id        String   @id @default(cuid())
  name      String
  order     Int
  startDate DateTime?
  endDate   DateTime?
  color     String    @default("#2563eb")
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Person {
  id               String   @id @default(cuid())
  name             String   @unique
  title            String?
  email            String?
  ownedTasks       Task[]   @relation("OwnerTasks")
  accountableTasks Task[]   @relation("AccountableTasks")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Task {
  id              String    @id @default(cuid())
  itemId          String?   @unique
  workstream      String
  category        String?
  title           String
  description     String?
  whyItMatters    String?
  output          String?
  artefactType    String?
  ownerRole       String?
  ownerId         String?
  owner           Person?   @relation("OwnerTasks", fields: [ownerId], references: [id])
  accountableId   String?
  accountable     Person?   @relation("AccountableTasks", fields: [accountableId], references: [id])
  contributors    String?
  priority        String?
  horizonId       String?
  horizon         Horizon?  @relation(fields: [horizonId], references: [id])
  targetDate      DateTime?
  status          String    @default("Not Started")
  completion      Int       @default(0)
  recurrence      String?
  cadence         String?
  dependencies    String?
  risks           String?
  evidence        String?
  doneCriteria    String?
  source          String?
  origin          String    @default("Transformation Plan (only)")
  notes           String?
  position        Int       @default(0)
  comments        Comment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([horizonId])
  @@index([workstream])
  @@index([status])
  @@index([origin])
}

model Comment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([taskId])
}
